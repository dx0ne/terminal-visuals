{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "final_space": true,
  "console_title_template": "{{ .Shell }} in {{ .Folder }}",
  "upgrade": {
    "source": "cdn",
    "interval": "168h",
    "auto": false,
    "notice": false
  },
  "secondary_prompt": {
    "template": "❯❯ ",
    "foreground": "lightBlue",
    "background": "transparent"
  },
  "transient_prompt": {
    "template": "<cyan> {{ .Folder }}</> ❯ ",
    "foreground": "lightBlue",
    "background": "transparent"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "path",
          "style": "plain",
          "foreground": "cyan",
          "background": "transparent",
          "options": {
            "style": "folder"
          },
          "template": " {{ path .Path .Location }}"
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "lightBlue",
          "background": "transparent",
          "options": {
            "branch_template": "{{ trunc 25 .Branch }}",
            "fetch_status": true
          },
          "template": " {{ .HEAD }}{{ $s := add .Staging.Added .Staging.Deleted .Staging.Modified .Staging.Unmerged }}{{ if gt $s 0 }} <green>+{{ $s }}</>{{ end }}{{ $w := add .Working.Modified .Working.Deleted .Working.Unmerged }}{{ if gt $w 0 }} <yellow>~{{ $w }}</>{{ end }}{{ if gt .Working.Untracked 0 }} <magenta>?{{ .Working.Untracked }}</>{{ end }}"
        },
        {
          "type": "root",
          "style": "plain",
          "foreground": "yellow",
          "background": "transparent",
          "template": " "
        },
        {
          "type": "status",
          "style": "plain",
          "foreground": "green",
          "background": "transparent",
          "options": {
            "always_enabled": true
          },
          "foreground_templates": [
            "{{ if gt .Code 0 }}red{{ end }}"
          ],
          "template": " ❯"
        }
      ]
    }
  ]
}
